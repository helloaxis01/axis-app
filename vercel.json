{
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/onboarding",
      "destination": "/onboarding.html"
    },
    {
      "source": "/onboarding-123pm",
      "destination": "/onboarding.html"
    },
    {
      "source": "/onboarding-911am",
      "destination": "/onboarding.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
