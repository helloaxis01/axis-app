{
  "rewrites": [
    {
      "source": "/",
      "destination": "/031726%20REBUILD/AXIS_master_mainapp.html"
    },
    {
      "source": "/onboarding",
      "destination": "/031726%20REBUILD/AXIS_master_onboarding.html"
    },
    {
      "source": "/onboarding-123pm",
      "destination": "/031726%20REBUILD/AXIS_master_onboarding.html"
    },
    {
      "source": "/onboarding-911am",
      "destination": "/031726%20REBUILD/AXIS_master_onboarding.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
