{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AXIS: dev + open in system browser (parent repo)",
      "type": "shell",
      "command": "npm run dev:open",
      "options": {
        "cwd": "${workspaceFolder}/..",
        "env": {
          "PORT": "3000"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "axis-static-dev",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "AXIS dev \\(no redirects\\):"
        }
      }
    },
    {
      "label": "AXIS: dev server only (parent repo)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/..",
        "env": {
          "PORT": "3000"
        }
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "axis-static-dev",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "AXIS dev \\(no redirects\\):"
        }
      }
    },
    {
      "label": "AXIS: open in system browser (use if Cursor panel is blank)",
      "type": "shell",
      "command": "open 'http://127.0.0.1:3000/' && open 'http://127.0.0.1:3000/onboarding.html'",
      "problemMatcher": []
    }
  ]
}
